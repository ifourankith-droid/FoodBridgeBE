@baseUrl = https://localhost:5001

### Health check
GET {{baseUrl}}/api/health


### --- Auth ---

### Send OTP
POST {{baseUrl}}/api/auth/send-otp
Content-Type: application/json

{
  "mobile": "9876543210"
}


### Verify OTP (read the code from console/logs — MockSmsProvider logs it)
POST {{baseUrl}}/api/auth/verify-otp
Content-Type: application/json

{
  "mobile": "9876543210",
  "code": "123456"
}


### Register (sessionToken = the `token` from verify-otp when isNewUser was true)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "sessionToken": "PASTE_SESSION_TOKEN_HERE",
  "role": "Volunteer",
  "name": "Test Volunteer",
  "city": "Ahmedabad",
  "address": "Satellite, Ahmedabad",
  "latitude": 23.03,
  "longitude": 72.55,
  "recipientType": null,
  "capacityMeals": null
}


### Register as Recipient (recipientType + capacityMeals required)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "sessionToken": "PASTE_SESSION_TOKEN_HERE",
  "role": "Recipient",
  "name": "Hope Community Kitchen",
  "city": "Ahmedabad",
  "address": "Paldi, Ahmedabad",
  "latitude": 23.01,
  "longitude": 72.56,
  "recipientType": "Organization",
  "capacityMeals": 200
}


### Me (requires a JWT — from verify-otp existing-user, or register)
GET {{baseUrl}}/api/auth/me
Authorization: Bearer PASTE_JWT_HERE


### Logout
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer PASTE_JWT_HERE


### --- Users ---
@userId = PASTE_USER_ID_HERE

### Get profile (self or admin)
GET {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer PASTE_JWT_HERE


### Update profile (self only; updates Location if lat/lng given)
PUT {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer PASTE_JWT_HERE
Content-Type: application/json

{
  "name": "Raj Patel",
  "city": "Ahmedabad",
  "address": "New Address, Satellite",
  "latitude": 23.05,
  "longitude": 72.54,
  "capacityMeals": null
}


### Toggle availability (self only; Volunteer/Recipient only)
PATCH {{baseUrl}}/api/users/{{userId}}/availability
Authorization: Bearer PASTE_JWT_HERE
Content-Type: application/json

{
  "isAvailable": false
}


### Upload avatar (self only; JPG/PNG, max 2MB)
POST {{baseUrl}}/api/users/{{userId}}/avatar
Authorization: Bearer PASTE_JWT_HERE
Content-Type: multipart/form-data; boundary=FoodBridgeBoundary

--FoodBridgeBoundary
Content-Disposition: form-data; name="file"; filename="avatar.jpg"
Content-Type: image/jpeg

< ./avatar.jpg
--FoodBridgeBoundary--


### --- Listings (Donor) ---
@listingId = PASTE_LISTING_ID_HERE

### Create a listing (DonorOnly)
POST {{baseUrl}}/api/listings
Authorization: Bearer PASTE_DONOR_JWT_HERE
Content-Type: application/json

{
  "title": "Surplus Wedding Catering",
  "foodType": "Mixed Veg Meals",
  "dietType": "Veg",
  "mealType": "Dinner",
  "quantityMeals": 80,
  "freshnessTag": "JustCooked",
  "preparedAtUtc": "2026-07-23T08:00:00Z",
  "pickupDeadlineUtc": "2026-07-23T14:00:00Z",
  "pickupAddress": "C.G. Road, Navrangpura",
  "latitude": 23.0338,
  "longitude": 72.5623
}


### List my listings (paginated, optional status filter)
GET {{baseUrl}}/api/listings?page=1&pageSize=20
Authorization: Bearer PASTE_DONOR_JWT_HERE


### List my listings filtered by status
GET {{baseUrl}}/api/listings?page=1&pageSize=20&status=Pending
Authorization: Bearer PASTE_DONOR_JWT_HERE


### Get listing detail (images + timeline)
GET {{baseUrl}}/api/listings/{{listingId}}
Authorization: Bearer PASTE_DONOR_JWT_HERE


### Update a listing (owner only; only while Pending — 422 otherwise)
PUT {{baseUrl}}/api/listings/{{listingId}}
Authorization: Bearer PASTE_DONOR_JWT_HERE
Content-Type: application/json

{
  "title": "Surplus Wedding Catering (updated)",
  "foodType": "Mixed Veg Meals",
  "dietType": "Veg",
  "mealType": "Dinner",
  "quantityMeals": 90,
  "freshnessTag": "FewHoursOld",
  "preparedAtUtc": "2026-07-23T08:00:00Z",
  "pickupDeadlineUtc": "2026-07-23T15:00:00Z",
  "pickupAddress": "C.G. Road, Navrangpura",
  "latitude": 23.0338,
  "longitude": 72.5623
}


### Cancel a listing (owner only; only while Pending — 422 otherwise)
POST {{baseUrl}}/api/listings/{{listingId}}/cancel
Authorization: Bearer PASTE_DONOR_JWT_HERE


### Upload a listing image (owner only; JPG/PNG, max 5MB; only while Pending)
POST {{baseUrl}}/api/listings/{{listingId}}/images
Authorization: Bearer PASTE_DONOR_JWT_HERE
Content-Type: multipart/form-data; boundary=FoodBridgeBoundary

--FoodBridgeBoundary
Content-Disposition: form-data; name="file"; filename="food.jpg"
Content-Type: image/jpeg

< ./food.jpg
--FoodBridgeBoundary--


### --- Listings (Volunteer) ---

### Nearby pending listings (default radius 10km, max 50km)
GET {{baseUrl}}/api/listings/nearby?latitude=23.0338&longitude=72.5623&radiusKm=15&page=1&pageSize=20
Authorization: Bearer PASTE_VOLUNTEER_JWT_HERE


### Claim a pending listing (optimistic concurrency; 409 if already claimed)
POST {{baseUrl}}/api/listings/{{listingId}}/claim
Authorization: Bearer PASTE_VOLUNTEER_JWT_HERE


### Confirm pickup (assigned volunteer only; requires photo; auto-matches nearest recipient)
POST {{baseUrl}}/api/listings/{{listingId}}/confirm-pickup
Authorization: Bearer PASTE_VOLUNTEER_JWT_HERE
Content-Type: multipart/form-data; boundary=FoodBridgeBoundary

--FoodBridgeBoundary
Content-Disposition: form-data; name="photo"; filename="pickup.jpg"
Content-Type: image/jpeg

< ./pickup.jpg
--FoodBridgeBoundary--


### Confirm delivery (assigned volunteer only; requires photo + matched recipient)
POST {{baseUrl}}/api/listings/{{listingId}}/confirm-delivery
Authorization: Bearer PASTE_VOLUNTEER_JWT_HERE
Content-Type: multipart/form-data; boundary=FoodBridgeBoundary

--FoodBridgeBoundary
Content-Disposition: form-data; name="photo"; filename="delivery.jpg"
Content-Type: image/jpeg

< ./delivery.jpg
--FoodBridgeBoundary--


### --- Listings (Recipient) ---

### Incoming matches (awaiting accept/reject)
GET {{baseUrl}}/api/listings/incoming?page=1&pageSize=20
Authorization: Bearer PASTE_RECIPIENT_JWT_HERE


### Accept an incoming match (doesn't change Status)
POST {{baseUrl}}/api/listings/{{listingId}}/accept
Authorization: Bearer PASTE_RECIPIENT_JWT_HERE


### Reject an incoming match (auto-reassigns to another available recipient)
POST {{baseUrl}}/api/listings/{{listingId}}/reject
Authorization: Bearer PASTE_RECIPIENT_JWT_HERE


### Confirm receipt (Delivered -> Confirmed; atomic points + certificate + notifications)
POST {{baseUrl}}/api/listings/{{listingId}}/confirm-receipt
Authorization: Bearer PASTE_RECIPIENT_JWT_HERE


### Receipt history (past confirmed receipts)
GET {{baseUrl}}/api/listings/history?page=1&pageSize=20
Authorization: Bearer PASTE_RECIPIENT_JWT_HERE
